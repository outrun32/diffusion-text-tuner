{
  "schema_version": "prompt-generation/v1",
  "mode": "simple",
  "seed": 42,
  "output_path": "data/prompts/simple.jsonl",
  "generation": {
    "n": 100,
    "no_llm": true,
    "model": "Qwen/Qwen3.5-4B",
    "backend": "transformers",
    "batch_size": 1,
    "temperature": 0.7,
    "expand_scenes": 0
  },
  "curriculum_stages": [
    {
      "name": "single_letters",
      "family": "single_letters",
      "weight": 1,
      "scripts": ["cyrillic"],
      "content_types": ["typography", "poster"],
      "tiers": [1],
      "cases": ["upper", "lower"],
      "languages": ["ru"]
    },
    {
      "name": "short_words",
      "family": "short_words",
      "weight": 3,
      "scripts": ["cyrillic"],
      "content_types": ["poster", "typography", "product"],
      "tiers": [1, 2],
      "cases": ["upper", "title", "lower"],
      "languages": ["ru"]
    }
  ],
  "validation_thresholds": {
    "min_rare_char_coverage": 0.02,
    "max_duplicate_rate": 0.15,
    "max_target_length": 32
  }
}
